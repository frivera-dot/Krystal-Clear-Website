---
import type { FAQ } from "../data/types";

interface Props {
  faqs: FAQ[];
  heading?: string;
  /** Emit FAQPage JSON-LD (use on at most one page section per URL) */
  withSchema?: boolean;
}
const { faqs, heading = "Frequently Asked Questions", withSchema = true } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<section class="mx-auto max-w-3xl px-4 py-14 sm:px-6">
  <h2 class="text-center text-2xl font-extrabold tracking-tight text-navy-900 sm:text-3xl">{heading}</h2>
  <div class="mt-8 space-y-3">
    {
      faqs.map((f) => (
        <details class="group rounded-xl border border-slate-100 bg-white shadow-sm open:shadow-md">
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-5 py-4 font-semibold text-navy-900 [&::-webkit-details-marker]:hidden">
            {f.q}
            <svg
              class="h-5 w-5 shrink-0 text-crystal-600 transition group-open:rotate-45"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path stroke-linecap="round" d="M12 5v14M5 12h14" />
            </svg>
          </summary>
          <p class="px-5 pb-5 leading-relaxed text-slate-600">{f.a}</p>
        </details>
      ))
    }
  </div>
</section>
{withSchema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
