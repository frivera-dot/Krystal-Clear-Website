---
import { SITE } from "../config/site";
import Logo from "./Logo.astro";
import { services } from "../data/services";
import { industries } from "../data/industries";
import { regions } from "../data/regions";

const year = new Date().getFullYear();
---

<footer class="bg-navy-950 text-navy-200">
  <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">
      <div>
        <a href="/" aria-label={`${SITE.fullName} — home`}>
          <Logo light />
        </a>
        <p class="mt-4 text-sm leading-relaxed">
          Commercial janitorial services and specialty floor care for {SITE.serviceAreaSummary.toLowerCase()}. Licensed, bonded &amp; insured.
        </p>
        <div class="mt-4 space-y-1 text-sm">
          <p>{SITE.address.street}</p>
          <p>{SITE.address.city}, {SITE.address.state} {SITE.address.zip}</p>
          <p>
            <a href={SITE.phoneHref} class="font-semibold text-crystal-300 hover:text-crystal-200">{SITE.phone}</a>
          </p>
        </div>
      </div>

      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-white">Services</h3>
        <ul class="mt-4 space-y-2 text-sm">
          {
            services.map((s) => (
              <li>
                <a href={`/services/${s.slug}/`} class="hover:text-crystal-300">
                  {s.shortName}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-white">Industries</h3>
        <ul class="mt-4 space-y-2 text-sm">
          {
            industries.map((i) => (
              <li>
                <a href={`/industries/${i.slug}/`} class="hover:text-crystal-300">
                  {i.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-white">Service Areas</h3>
        <ul class="mt-4 space-y-2 text-sm">
          {
            regions.map((r) => (
              <li>
                <a href={`/service-areas/${r.slug}/`} class="hover:text-crystal-300">
                  {r.name}
                </a>
              </li>
            ))
          }
          <li>
            <a href="/locations/" class="font-semibold text-crystal-300 hover:text-crystal-200">
              All locations →
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-start justify-between gap-4 border-t border-navy-800 pt-6 text-xs text-navy-300 sm:flex-row sm:items-center">
      <p>© {year} {SITE.legalName}. All rights reserved.</p>
      <div class="flex gap-5">
        <a href="/privacy-policy/" class="hover:text-crystal-300">Privacy Policy</a>
        <a href="/terms-of-service/" class="hover:text-crystal-300">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
