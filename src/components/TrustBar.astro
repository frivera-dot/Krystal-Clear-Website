---
import { SITE } from "../config/site";

// Spec-sheet strip: reads like the header row of a work order.
const items = [
  { label: "Licensed · Bonded · Insured", num: "COI on request" },
  { label: "Floor care expertise", num: `${SITE.yearsFloorExperience}+ years` },
  { label: "Service scope", num: "Commercial only" },
  { label: "Crew schedule", num: "Nights & weekends" },
];
---

<div class="border-y border-pine-900/15 bg-pine-50">
  <div class="mx-auto grid max-w-7xl grid-cols-2 divide-pine-900/10 px-4 py-4 max-lg:gap-y-4 sm:px-6 lg:grid-cols-4 lg:divide-x">
    {
      items.map((item) => (
        <div class="lg:px-6 lg:first:pl-0 lg:last:pr-0">
          <p class="eyebrow text-pine-700">{item.label}</p>
          <p class="mt-0.5 font-display text-lg font-bold uppercase text-pine-900">{item.num}</p>
        </div>
      ))
    }
  </div>
</div>
