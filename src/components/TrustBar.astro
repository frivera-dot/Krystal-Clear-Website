---
import { SITE } from "../config/site";

const items = [
  { label: "Licensed, Bonded & Insured", icon: "shield" },
  { label: `${SITE.yearsFloorExperience}+ Years of Floor Care Expertise`, icon: "star" },
  { label: "Commercial Only — No Residential", icon: "building" },
  { label: "Night & Weekend Crews", icon: "moon" },
];
---

<div class="border-y border-slate-100 bg-navy-50/60">
  <div class="mx-auto grid max-w-7xl grid-cols-2 gap-4 px-4 py-5 sm:px-6 lg:grid-cols-4">
    {
      items.map((item) => (
        <div class="flex items-center gap-2.5">
          <svg class="h-5 w-5 shrink-0 text-crystal-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            {item.icon === "shield" && <path stroke-linecap="round" stroke-linejoin="round" d="M12 3l7 3v5c0 4.5-3 8.5-7 10-4-1.5-7-5.5-7-10V6l7-3z" />}
            {item.icon === "star" && <path stroke-linecap="round" stroke-linejoin="round" d="M12 3l2.7 5.8 6.3.8-4.6 4.3 1.2 6.1L12 17l-5.6 3 1.2-6.1L3 9.6l6.3-.8L12 3z" />}
            {item.icon === "building" && <path stroke-linecap="round" stroke-linejoin="round" d="M4 21V5a2 2 0 012-2h8a2 2 0 012 2v16M4 21h16M8 7h2m-2 4h2m-2 4h2m4-8h2v14" />}
            {item.icon === "moon" && <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.8A8.5 8.5 0 1111.2 3a7 7 0 009.8 9.8z" />}
          </svg>
          <span class="text-xs font-semibold text-navy-900 sm:text-sm">{item.label}</span>
        </div>
      ))
    }
  </div>
</div>
