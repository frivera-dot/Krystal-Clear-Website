---
// Netlify Forms-ready quote form. Works once deployed to Netlify (form name: "quote").
import { services } from "../data/services";

interface Props {
  heading?: string;
}
const { heading = "Request a Free Quote" } = Astro.props;
---

<div class="border border-pine-900/20 bg-white shadow-[4px_4px_0_0_rgba(18,50,39,0.14)]">
  <div class="flex items-center justify-between gap-3 border-b-2 border-brass-500 bg-pine-900 px-6 py-3">
    <h3 class="font-display text-lg font-bold uppercase tracking-wide text-white">{heading}</h3>
    <span class="eyebrow hidden text-brass-300 sm:block">No. 001</span>
  </div>
  <div class="p-6 sm:p-7">
  <p class="eyebrow text-pine-700">Free walkthrough · Flat quote · No pressure</p>
  <form
    name="quote"
    method="POST"
    action="/thank-you/"
    data-netlify="true"
    netlify-honeypot="bot-field"
    class="mt-5 space-y-4"
  >
    <input type="hidden" name="form-name" value="quote" />
    <p class="hidden">
      <label>Don't fill this out: <input name="bot-field" /></label>
    </p>
    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <label for="q-name" class="mb-1 block text-sm font-semibold text-pine-900">Name</label>
        <input
          id="q-name"
          name="name"
          required
          autocomplete="name"
          class="w-full border border-stone-300 px-3.5 py-2.5 text-sm focus:border-pine-700 focus:outline-none focus:ring-2 focus:ring-pine-700/15"
        />
      </div>
      <div>
        <label for="q-company" class="mb-1 block text-sm font-semibold text-pine-900">Company / Facility</label>
        <input
          id="q-company"
          name="company"
          autocomplete="organization"
          class="w-full border border-stone-300 px-3.5 py-2.5 text-sm focus:border-pine-700 focus:outline-none focus:ring-2 focus:ring-pine-700/15"
        />
      </div>
      <div>
        <label for="q-phone" class="mb-1 block text-sm font-semibold text-pine-900">Phone</label>
        <input
          id="q-phone"
          name="phone"
          type="tel"
          required
          autocomplete="tel"
          class="w-full border border-stone-300 px-3.5 py-2.5 text-sm focus:border-pine-700 focus:outline-none focus:ring-2 focus:ring-pine-700/15"
        />
      </div>
      <div>
        <label for="q-email" class="mb-1 block text-sm font-semibold text-pine-900">Email</label>
        <input
          id="q-email"
          name="email"
          type="email"
          required
          autocomplete="email"
          class="w-full border border-stone-300 px-3.5 py-2.5 text-sm focus:border-pine-700 focus:outline-none focus:ring-2 focus:ring-pine-700/15"
        />
      </div>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <label for="q-city" class="mb-1 block text-sm font-semibold text-pine-900">Facility City</label>
        <input
          id="q-city"
          name="city"
          placeholder="e.g. Walnut Creek"
          class="w-full border border-stone-300 px-3.5 py-2.5 text-sm focus:border-pine-700 focus:outline-none focus:ring-2 focus:ring-pine-700/15"
        />
      </div>
      <div>
        <label for="q-service" class="mb-1 block text-sm font-semibold text-pine-900">Service Needed</label>
        <select
          id="q-service"
          name="service"
          class="w-full border border-stone-300 bg-white px-3.5 py-2.5 text-sm focus:border-pine-700 focus:outline-none focus:ring-2 focus:ring-pine-700/15"
        >
          <option value="">Not sure yet</option>
          {services.map((s) => <option value={s.name}>{s.name}</option>)}
        </select>
      </div>
    </div>
    <div>
      <label for="q-message" class="mb-1 block text-sm font-semibold text-pine-900">Tell us about your facility</label>
      <textarea
        id="q-message"
        name="message"
        rows="3"
        placeholder="Square footage, floor types, cleaning frequency, anything else…"
        class="w-full border border-stone-300 px-3.5 py-2.5 text-sm focus:border-pine-700 focus:outline-none focus:ring-2 focus:ring-pine-700/15"></textarea>
    </div>
    <button
      type="submit"
      class="w-full bg-brass-500 px-6 py-3.5 font-display text-lg font-bold uppercase tracking-wider text-pine-950 transition hover:bg-brass-400"
    >
      Get My Free Quote
    </button>
    <p class="text-center text-xs text-stone-500">Commercial facilities only — we don't offer residential cleaning.</p>
  </form>
  </div>
</div>
