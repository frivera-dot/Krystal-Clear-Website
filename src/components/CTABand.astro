---
import { SITE } from "../config/site";

interface Props {
  heading?: string;
  sub?: string;
}
const {
  heading = "Walk the floor with us.",
  sub = "Tell us about your building and we'll schedule a free walkthrough — then send a flat, no-surprises quote.",
} = Astro.props;
---

<section class="border-t-4 border-brass-500 bg-pine-950">
  <div class="mx-auto flex max-w-7xl flex-col items-center gap-8 px-4 py-16 text-center sm:px-6 lg:flex-row lg:justify-between lg:text-left">
    <div>
      <p class="eyebrow text-brass-300">Free walkthrough · Flat quote</p>
      <h2 class="mt-2 font-display text-3xl font-bold uppercase text-white sm:text-4xl">{heading}</h2>
      <p class="mt-3 max-w-2xl text-pine-100">{sub}</p>
    </div>
    <div class="flex shrink-0 flex-col gap-3 sm:flex-row">
      <a
        href="/contact/"
        class="bg-brass-500 px-7 py-4 text-center font-display text-lg font-bold uppercase tracking-wider text-pine-950 hover:bg-brass-400"
      >
        Get a Free Quote
      </a>
      <a
        href={SITE.phoneHref}
        class="border border-pine-100/40 px-7 py-4 text-center font-display text-lg font-bold uppercase tracking-wider text-white hover:border-brass-400 hover:text-brass-300"
      >
        {SITE.phone}
      </a>
    </div>
  </div>
</section>
