---
import Layout from "../../../layouts/Layout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import CTABand from "../../../components/CTABand.astro";
import QuoteForm from "../../../components/QuoteForm.astro";
import FAQSection from "../../../components/FAQSection.astro";
import { SITE } from "../../../config/site";
import { cities, cityBySlug } from "../../../data/cities";
import { services } from "../../../data/services";
import { industries } from "../../../data/industries";
import { regionBySlug } from "../../../data/regions";

export function getStaticPaths() {
  return cities.map((city) => ({ params: { city: city.slug }, props: { city } }));
}

const { city } = Astro.props;
const region = regionBySlug(city.region);
const coreServices = services.filter((s) => s.isCore);
const specialtyServices = services.filter((s) => !s.isCore);
const nearby = city.nearby.map((slug) => {
  try {
    return cityBySlug(slug);
  } catch {
    return null;
  }
}).filter((c) => c !== null);

const cityFaqs = [
  {
    q: `Do you provide commercial cleaning in ${city.name}?`,
    a: `Yes — ${city.name} is part of our core ${region.name} service area. Our crews handle recurring janitorial contracts, deep cleans, floor care, and post-construction cleanup for ${city.name} businesses, with free on-site walkthroughs before every quote.`,
  },
  {
    q: `What types of ${city.name} facilities do you clean?`,
    a: `In ${city.name} we focus on ${city.clientTypes.join(", ")}. We're commercial-only — no residential — so our crews and equipment are built for business facilities.`,
  },
  {
    q: `How fast can you start service in ${city.name}?`,
    a: `Typically within a week of your walkthrough. Call ${SITE.phone} and we'll schedule a visit to your ${city.name} facility, usually within a couple of business days.`,
  },
  {
    q: `Do you clean after business hours in ${city.name}?`,
    a: `Yes. Most ${city.name} accounts are serviced at night or on weekends so there's zero disruption to your team, tenants, or students. Day porter service is available too.`,
  },
];

const localSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: `Commercial Cleaning in ${city.name}, CA`,
  serviceType: "Commercial Cleaning",
  provider: { "@id": `${SITE.domain}/#business` },
  areaServed: {
    "@type": "City",
    name: city.name,
    containedInPlace: { "@type": "AdministrativeArea", name: city.county },
  },
};
---

<Layout
  title={`Commercial Cleaning in ${city.name}, CA | KCS Krystal Clear Service`}
  description={`Commercial janitorial & floor care in ${city.name}, CA — offices, schools, medical & more. Licensed, bonded & insured. Free walkthrough: (925) 301-5566.`}
  schema={[localSchema]}
>
  <Breadcrumbs
    crumbs={[
      { label: "Service Areas", href: "/locations/" },
      { label: region.name, href: `/service-areas/${region.slug}/` },
      { label: city.name },
    ]}
  />

  <section class="mx-auto grid max-w-7xl gap-12 px-4 py-10 sm:px-6 lg:grid-cols-[1fr_24rem]">
    <div>
      <p class="text-sm font-bold uppercase tracking-wider text-brass-600">{city.county}</p>
      <h1 class="mt-2 text-4xl font-extrabold tracking-tight text-pine-900">
        Commercial Cleaning in {city.name}, CA
      </h1>
      <div class="copy mt-6 max-w-3xl text-stone-700">
        <p>{city.intro}</p>
      </div>

      <h2 class="mt-10 text-2xl font-extrabold tracking-tight text-pine-900">
        Our Services in {city.name}
      </h2>
      <div class="mt-5 grid gap-4 sm:grid-cols-2">
        {
          coreServices.map((s) => (
            <a
              href={`/locations/${city.slug}/${s.slug}/`}
              class="group rounded-xl border border-stone-200 bg-white p-5 shadow-sm transition hover:border-pine-700"
            >
              <h3 class="font-bold text-pine-900 group-hover:text-brass-700">
                {s.shortName} in {city.name}
              </h3>
              <p class="mt-1.5 text-sm text-stone-600">{s.blurb}</p>
              <span class="mt-3 inline-block text-sm font-bold text-brass-600">Details →</span>
            </a>
          ))
        }
      </div>
      <p class="mt-4 text-sm text-stone-500">
        Also available in {city.name}:{" "}
        {specialtyServices.map((s, i) => (
          <>
            <a href={`/services/${s.slug}/`} class="font-semibold text-brass-700 hover:text-brass-600">
              {s.shortName}
            </a>
            {i < specialtyServices.length - 1 ? ", " : ""}
          </>
        ))}
      </p>

      <h2 class="mt-10 text-2xl font-extrabold tracking-tight text-pine-900">
        The {city.name} Business Landscape
      </h2>
      <div class="copy mt-4 max-w-3xl text-stone-700">
        <p>{city.businessLandscape}</p>
      </div>
      <div class="mt-6 grid gap-6 sm:grid-cols-2">
        <div class="rounded-xl border border-stone-200 bg-stone-50 p-5">
          <h3 class="text-sm font-bold uppercase tracking-wider text-pine-900">Areas We Cover</h3>
          <ul class="mt-3 space-y-1.5 text-sm text-stone-600">
            {city.districts.map((d) => <li>· {d}</li>)}
          </ul>
        </div>
        <div class="rounded-xl border border-stone-200 bg-stone-50 p-5">
          <h3 class="text-sm font-bold uppercase tracking-wider text-pine-900">Facilities We Serve Here</h3>
          <ul class="mt-3 space-y-1.5 text-sm capitalize text-stone-600">
            {city.clientTypes.map((t) => <li>· {t}</li>)}
          </ul>
        </div>
      </div>

      {
        nearby.length > 0 && (
          <>
            <h2 class="mt-10 text-xl font-extrabold tracking-tight text-pine-900">Nearby Service Areas</h2>
            <div class="mt-4 flex flex-wrap gap-3">
              {nearby.map((n) => (
                <a
                  href={`/locations/${n.slug}/`}
                  class="rounded-lg border border-stone-200 bg-white px-4 py-2 text-sm font-semibold text-pine-900 shadow-sm hover:border-brass-200 hover:text-brass-700"
                >
                  {n.name}
                </a>
              ))}
            </div>
          </>
        )
      }
    </div>

    <aside class="lg:sticky lg:top-24 lg:self-start">
      <QuoteForm heading={`Get a Free Quote in ${city.name}`} />
    </aside>
  </section>

  <FAQSection faqs={cityFaqs} heading={`${city.name} Commercial Cleaning FAQs`} />
  <CTABand heading={`Need a dependable cleaning crew in ${city.name}?`} />
</Layout>
