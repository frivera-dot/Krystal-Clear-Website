---
import Layout from "../layouts/Layout.astro";
import { SITE } from "../config/site";
---

<Layout
  title="Thank You | KCS Krystal Clear Service"
  description="We received your request and will be in touch shortly to schedule your free walkthrough."
>
  <section class="mx-auto flex max-w-2xl flex-col items-center px-4 py-24 text-center sm:px-6">
    <span class="flex h-16 w-16 items-center justify-center rounded-full bg-brass-100">
      <svg class="h-8 w-8 text-brass-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
    </span>
    <h1 class="mt-6 text-3xl font-extrabold tracking-tight text-pine-900">Request received — thank you!</h1>
    <p class="mt-4 text-lg text-stone-600">
      We'll reach out shortly to schedule your free walkthrough. Need us sooner? Call
      <a href={SITE.phoneHref} class="font-bold text-brass-700 hover:text-brass-600">{SITE.phone}</a>.
    </p>
    <a href="/" class="mt-8 rounded-lg bg-pine-900 px-6 py-3 font-bold text-white hover:bg-pine-800">Back to Home</a>
  </section>
</Layout>
