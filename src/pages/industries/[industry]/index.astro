---
import Layout from "../../../layouts/Layout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import CTABand from "../../../components/CTABand.astro";
import QuoteForm from "../../../components/QuoteForm.astro";
import FAQSection from "../../../components/FAQSection.astro";
import { industries } from "../../../data/industries";
import { services } from "../../../data/services";

export function getStaticPaths() {
  return industries.map((industry) => ({ params: { industry: industry.slug }, props: { industry } }));
}

const { industry } = Astro.props;
const relevantServices = industry.services
  .map((slug) => services.find((s) => s.slug === slug))
  .filter((s) => s !== undefined);
---

<Layout title={industry.metaTitle} description={industry.metaDescription}>
  <Breadcrumbs crumbs={[{ label: "Industries", href: "/industries/" }, { label: industry.name }]} />

  <section class="mx-auto grid max-w-7xl gap-12 px-4 py-10 sm:px-6 lg:grid-cols-[1fr_24rem]">
    <div>
      <h1 class="text-4xl font-extrabold tracking-tight text-navy-900">{industry.heroHeadline}</h1>
      <p class="mt-4 text-lg leading-relaxed text-slate-600">{industry.heroSub}</p>

      <div class="copy mt-8 max-w-3xl text-slate-700">
        {industry.overview.map((p) => <p>{p}</p>)}
      </div>

      <h2 class="mt-12 text-2xl font-extrabold tracking-tight text-navy-900">Challenges We Solve</h2>
      <div class="mt-6 grid gap-5 sm:grid-cols-2">
        {
          industry.painPoints.map((f) => (
            <div class="rounded-xl border border-slate-100 bg-white p-5 shadow-sm">
              <h3 class="font-bold text-navy-900">{f.title}</h3>
              <p class="mt-1.5 text-sm leading-relaxed text-slate-600">{f.description}</p>
            </div>
          ))
        }
      </div>

      <h2 class="mt-12 text-2xl font-extrabold tracking-tight text-navy-900">Services for {industry.name}</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        {
          relevantServices.map((s) => (
            <a
              href={`/services/${s.slug}/`}
              class="group rounded-xl border border-slate-100 bg-white p-5 shadow-sm transition hover:border-crystal-200 hover:shadow-md"
            >
              <h3 class="font-bold text-navy-900 group-hover:text-crystal-700">{s.name}</h3>
              <p class="mt-1.5 text-sm text-slate-600">{s.blurb}</p>
            </a>
          ))
        }
      </div>
    </div>

    <aside class="lg:sticky lg:top-24 lg:self-start">
      <QuoteForm heading={`Get a Quote for Your Facility`} />
    </aside>
  </section>

  <FAQSection faqs={industry.faqs} heading={`${industry.name} FAQs`} />
  <CTABand />
</Layout>
