---
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import CTABand from "../../components/CTABand.astro";
import TrustBar from "../../components/TrustBar.astro";
import { industries } from "../../data/industries";
---

<Layout
  title="Industries We Serve | KCS Krystal Clear Service"
  description="Commercial cleaning for offices, private schools, medical facilities, gyms, churches, HOAs, property managers & retail across the Bay Area & Sacramento."
>
  <Breadcrumbs crumbs={[{ label: "Industries" }]} />

  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6">
    <div class="max-w-3xl">
      <h1 class="text-4xl font-extrabold tracking-tight text-pine-900">Industries We Serve</h1>
      <p class="mt-4 text-lg leading-relaxed text-stone-600">
        Every facility type has its own standards, schedules, and headaches. Our crews are trained for the specific
        demands of each — from private school campuses that need background-checked night crews to medical suites with
        strict disinfection protocols.
      </p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        industries.map((i) => (
          <a
            href={`/industries/${i.slug}/`}
            class="group rounded-2xl border border-stone-200 bg-white p-6 shadow-sm transition hover:border-brass-200"
          >
            <h2 class="text-lg font-bold text-pine-900 group-hover:text-brass-700">{i.name}</h2>
            <p class="mt-2 text-sm leading-relaxed text-stone-600">{i.blurb}</p>
            <span class="mt-4 inline-block text-sm font-bold text-brass-600">Learn more →</span>
          </a>
        ))
      }
    </div>
  </section>

  <TrustBar />
  <CTABand />
</Layout>
