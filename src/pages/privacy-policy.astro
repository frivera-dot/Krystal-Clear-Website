---
import Layout from "../layouts/Layout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { SITE } from "../config/site";
---

<Layout
  title="Privacy Policy | KCS Krystal Clear Service"
  description="How KCS — Krystal Clear Service collects, uses, and protects information submitted through this website."
>
  <Breadcrumbs crumbs={[{ label: "Privacy Policy" }]} />
  <section class="copy mx-auto max-w-3xl px-4 py-10 text-slate-700 sm:px-6">
    <h1 class="mb-6 text-3xl font-extrabold tracking-tight text-navy-900">Privacy Policy</h1>
    <p>
      {SITE.legalName} ("KCS," "we," "us") respects your privacy. This policy explains what information we collect
      through this website and how we use it.
    </p>
    <h2 class="mb-3 mt-8 text-xl font-bold text-navy-900">Information We Collect</h2>
    <p>
      When you submit a quote request or contact form, we collect the information you provide: name, company, phone
      number, email address, facility location, and details about the services you're interested in. We also collect
      basic, non-identifying analytics data about how visitors use the site.
    </p>
    <h2 class="mb-3 mt-8 text-xl font-bold text-navy-900">How We Use It</h2>
    <p>
      We use your information to respond to your inquiry, schedule walkthroughs, prepare quotes, and provide our
      services. We do not sell, rent, or share your personal information with third parties for their marketing
      purposes.
    </p>
    <h2 class="mb-3 mt-8 text-xl font-bold text-navy-900">Data Retention &amp; Security</h2>
    <p>
      We retain inquiry information only as long as needed for business purposes and take reasonable measures to
      protect it from unauthorized access.
    </p>
    <h2 class="mb-3 mt-8 text-xl font-bold text-navy-900">Contact</h2>
    <p>
      Questions about this policy? Call us at {SITE.phone} or write to {SITE.address.street}, {SITE.address.city},
      {SITE.address.state} {SITE.address.zip}.
    </p>
  </section>
</Layout>
