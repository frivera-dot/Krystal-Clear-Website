---
import Layout from "../layouts/Layout.astro";
import TrustBar from "../components/TrustBar.astro";
import QuoteForm from "../components/QuoteForm.astro";
import CTABand from "../components/CTABand.astro";
import FAQSection from "../components/FAQSection.astro";
import { SITE } from "../config/site";
import { services } from "../data/services";
import { industries } from "../data/industries";
import { regions } from "../data/regions";
import { citiesInRegion } from "../data/cities";

const coreServices = services.filter((s) => s.isCore);
const specialtyServices = services.filter((s) => !s.isCore);

const homeFaqs = [
  {
    q: "Do you offer residential cleaning?",
    a: "No — KCS is 100% commercial. We clean offices, schools, medical facilities, gyms, churches, HOA common areas, and retail spaces. Keeping our focus commercial means our crews, equipment, and processes are built for business facilities.",
  },
  {
    q: "What areas do you serve?",
    a: `We serve ${SITE.serviceAreaSummary} — from our Pleasant Hill headquarters we cover Contra Costa County, the Tri-Valley, Oakland and the East Bay, downtown San Francisco, Solano County, the Sacramento area, and the Central Valley down to Modesto.`,
  },
  {
    q: "How does pricing work?",
    a: "Every facility is different, so we start with a free walkthrough. We look at square footage, floor types, traffic, and your schedule, then send a flat monthly or per-job quote. No hidden fees and no lock-in surprises.",
  },
  {
    q: "Are you licensed and insured?",
    a: "Yes — KCS is licensed, bonded, and insured. We're happy to provide certificates of insurance for your property manager or building requirements before we start.",
  },
  {
    q: "Can you clean after hours?",
    a: "Absolutely. Most of our janitorial accounts are serviced at night or on weekends so your business never skips a beat. Day porter-style visits are available too.",
  },
  {
    q: "What makes KCS different from other janitorial companies?",
    a: `Floors. Our founder spent ${SITE.yearsFloorExperience}+ years mastering floor care — stripping and waxing, concrete polishing, marble and stone restoration — before building KCS. Most janitorial companies subcontract floor work; we're the specialists others call.`,
  },
];
---

<Layout
  title="Commercial Janitorial Services & Floor Care | KCS Krystal Clear Service"
  description="Commercial janitorial services & specialty floor care for the Bay Area, Sacramento & Central Valley. Licensed, bonded & insured. Free walkthrough: (925) 301-5566."
>
  <!-- Hero: the wet-floor reflection is the signature -->
  <section class="relative overflow-hidden bg-pine-950">
    <div class="relative mx-auto grid max-w-7xl gap-12 px-4 pb-14 pt-16 sm:px-6 lg:grid-cols-[1.15fr_1fr] lg:items-center lg:pb-20 lg:pt-24">
      <div>
        <p class="eyebrow text-brass-300">
          Commercial janitorial &amp; floor care — Pleasant Hill, CA
        </p>
        <div class="mt-4 pb-14 sm:pb-20">
          <div class="relative">
            <h1 class="font-display text-5xl font-bold uppercase leading-[0.95] text-white sm:text-7xl">
              Krystal clear floors.<br />
              <span class="text-brass-400">Spotless</span> everything else.
            </h1>
            <div class="mt-4 h-px w-full max-w-xl bg-brass-500/70"></div>
            <p
              aria-hidden="true"
              class="reflection-copy absolute left-0 top-full mt-1 w-full font-display text-5xl font-bold uppercase leading-[0.95] text-white sm:text-7xl"
            >
              Krystal clear floors.<br />
              <span class="text-brass-400">Spotless</span> everything else.
            </p>
          </div>
        </div>
        <p class="relative mt-2 max-w-xl text-lg leading-relaxed text-pine-100">
          Nightly janitorial, deep cleans, and post-construction cleanup for offices, schools, medical, gyms,
          churches, and HOAs across Northern California — built on {SITE.yearsFloorExperience}+ years of stripping,
          sealing, and polishing commercial floors.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href="/contact/"
            class="bg-brass-500 px-7 py-4 text-center font-display text-lg font-bold uppercase tracking-wider text-pine-950 hover:bg-brass-400"
          >
            Schedule a Free Walkthrough
          </a>
          <a
            href={SITE.phoneHref}
            class="border border-pine-100/40 px-7 py-4 text-center font-display text-lg font-bold uppercase tracking-wider text-white hover:border-brass-400 hover:text-brass-300"
          >
            {SITE.phone}
          </a>
        </div>
        <div class="mt-9 border-t border-pine-100/15 pt-4">
          <p class="eyebrow text-pine-300">
            Trusted by&ensp;{SITE.featuredClients.map((c) => c.name).join("  ·  ")}
          </p>
        </div>
      </div>
      <div class="lg:pl-4">
        <QuoteForm />
      </div>
    </div>
  </section>

  <TrustBar />

  <!-- Services -->
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-extrabold tracking-tight text-pine-900">Commercial Cleaning Services</h2>
      <p class="mt-3 text-stone-600">
        Everything your facility needs under one roof — recurring janitorial contracts, one-time deep cleans, and the
        specialty floor work other companies subcontract to us.
      </p>
    </div>
    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        [...coreServices, ...specialtyServices.slice(0, 1)].map((s) => (
          <a
            href={`/services/${s.slug}/`}
            class="group rounded-2xl border border-stone-200 bg-white p-6 shadow-sm transition hover:border-brass-200"
          >
            <h3 class="text-lg font-bold text-pine-900 group-hover:text-brass-700">{s.name}</h3>
            <p class="mt-2 text-sm leading-relaxed text-stone-600">{s.blurb}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-bold text-brass-600">
              Learn more
              <svg class="h-4 w-4 transition group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-6-6l6 6-6 6" />
              </svg>
            </span>
          </a>
        ))
      }
    </div>
    <p class="mt-8 text-center">
      <a href="/services/" class="font-bold text-brass-700 hover:text-brass-600">View all {services.length} services →</a>
    </p>
  </section>

  <!-- Floor care specialty -->
  <section class="bg-pine-900">
    <div class="mx-auto grid max-w-7xl gap-10 px-4 py-16 sm:px-6 lg:grid-cols-2 lg:items-center">
      <div>
        <p class="text-sm font-bold uppercase tracking-wider text-brass-400">Our Specialty</p>
        <h2 class="mt-2 text-3xl font-extrabold tracking-tight text-white">
          The Floor Care Specialists Other Companies Call
        </h2>
        <p class="mt-4 leading-relaxed text-pine-200">
          Before KCS existed, our founder spent {SITE.yearsFloorExperience}+ years stripping, sealing, and polishing
          floors across the Bay Area. That expertise is still the heart of the company: VCT stripping &amp; waxing,
          diamond-ground concrete polishing, and marble &amp; natural stone restoration done in-house — never
          subcontracted.
        </p>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <a
            href="/services/commercial-floor-care/"
            class="rounded-lg bg-brass-500 px-6 py-3.5 text-center font-bold text-white hover:bg-brass-400"
          >
            Explore Floor Care
          </a>
        </div>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        {
          ["floor-stripping-and-waxing", "concrete-polishing", "marble-and-stone-polishing", "commercial-carpet-cleaning"].map(
            (slug) => {
              const s = services.find((x) => x.slug === slug)!;
              return (
                <a
                  href={`/services/${s.slug}/`}
                  class="rounded-xl border border-pine-700 bg-pine-800/60 p-5 transition hover:border-brass-500/50 hover:bg-pine-800"
                >
                  <h3 class="font-bold text-white">{s.shortName}</h3>
                  <p class="mt-1.5 text-sm text-pine-300">{s.blurb}</p>
                </a>
              );
            }
          )
        }
      </div>
    </div>
  </section>

  <!-- Industries -->
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-extrabold tracking-tight text-pine-900">Who We Clean For</h2>
      <p class="mt-3 text-stone-600">
        From Class-A office towers to private school campuses, our crews are trained for the facilities that demand
        more than a mop and a promise.
      </p>
    </div>
    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        industries.map((i) => (
          <a
            href={`/industries/${i.slug}/`}
            class="group rounded-xl border border-stone-200 bg-white p-5 text-center shadow-sm transition hover:border-pine-700"
          >
            <h3 class="font-bold text-pine-900 group-hover:text-brass-700">{i.name}</h3>
            <p class="mt-1.5 text-xs leading-relaxed text-stone-500">{i.blurb}</p>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Service areas -->
  <section class="border-t border-stone-200 bg-stone-50">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-extrabold tracking-tight text-pine-900">Serving Northern California</h2>
        <p class="mt-3 text-stone-600">
          Headquartered in Pleasant Hill with crews across {SITE.serviceAreaSummary.toLowerCase()}.
        </p>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          regions.map((r) => (
            <div class="rounded-2xl border border-stone-200 bg-white p-6 shadow-sm">
              <a href={`/service-areas/${r.slug}/`} class="text-lg font-bold text-pine-900 hover:text-brass-700">
                {r.name}
              </a>
              <div class="mt-3 flex flex-wrap gap-x-3 gap-y-1.5">
                {citiesInRegion(r.slug).map((c) => (
                  <a href={`/locations/${c.slug}/`} class="text-sm text-stone-500 hover:text-brass-700">
                    {c.name}
                  </a>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <FAQSection faqs={homeFaqs} />

  <CTABand />
</Layout>
