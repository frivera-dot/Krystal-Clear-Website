---
import Layout from "../../../layouts/Layout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import CTABand from "../../../components/CTABand.astro";
import QuoteForm from "../../../components/QuoteForm.astro";
import FAQSection from "../../../components/FAQSection.astro";
import { SITE } from "../../../config/site";
import { services } from "../../../data/services";
import { regions } from "../../../data/regions";
import { citiesInRegion } from "../../../data/cities";

export function getStaticPaths() {
  return services.map((service) => ({ params: { service: service.slug }, props: { service } }));
}

const { service } = Astro.props;

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: service.name,
  serviceType: service.name,
  provider: { "@id": `${SITE.domain}/#business` },
  areaServed: SITE.serviceAreaSummary,
  description: service.metaDescription,
};

const related = services.filter((s) => s.slug !== service.slug).slice(0, 4);
---

<Layout title={service.metaTitle} description={service.metaDescription} schema={[serviceSchema]}>
  <Breadcrumbs crumbs={[{ label: "Services", href: "/services/" }, { label: service.shortName }]} />

  <section class="mx-auto grid max-w-7xl gap-12 px-4 py-10 sm:px-6 lg:grid-cols-[1fr_24rem]">
    <div>
      <h1 class="text-4xl font-extrabold tracking-tight text-pine-900">{service.heroHeadline}</h1>
      <p class="mt-4 text-lg leading-relaxed text-stone-600">{service.heroSub}</p>

      <div class="copy mt-8 max-w-3xl text-stone-700">
        {service.overview.map((p) => <p>{p}</p>)}
      </div>

      <h2 class="mt-12 text-2xl font-extrabold tracking-tight text-pine-900">What's Included</h2>
      <div class="mt-6 grid gap-5 sm:grid-cols-2">
        {
          service.features.map((f) => (
            <div class="rounded-xl border border-stone-200 bg-white p-5 shadow-sm">
              <h3 class="font-bold text-pine-900">{f.title}</h3>
              <p class="mt-1.5 text-sm leading-relaxed text-stone-600">{f.description}</p>
            </div>
          ))
        }
      </div>

      <h2 class="mt-12 text-2xl font-extrabold tracking-tight text-pine-900">How It Works</h2>
      <ol class="mt-6 space-y-5">
        {
          service.process.map((step, i) => (
            <li class="flex gap-4">
              <span class="flex h-9 w-9 shrink-0 items-center justify-center bg-pine-900 font-display text-lg font-bold text-brass-300">
                {i + 1}
              </span>
              <div>
                <h3 class="font-bold text-pine-900">{step.title}</h3>
                <p class="mt-1 text-sm leading-relaxed text-stone-600">{step.description}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>

    <aside class="space-y-6 lg:sticky lg:top-24 lg:self-start">
      <QuoteForm heading={`Get a ${service.shortName} Quote`} />
      <div class="rounded-2xl border border-stone-200 bg-stone-50 p-6">
        <h3 class="font-bold text-pine-900">Other Services</h3>
        <ul class="mt-3 space-y-2 text-sm">
          {
            related.map((s) => (
              <li>
                <a href={`/services/${s.slug}/`} class="text-stone-600 hover:text-brass-700">
                  {s.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </aside>
  </section>

  {
    service.isCore && (
      <section class="border-t border-stone-200 bg-stone-50">
        <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6">
          <h2 class="text-center text-2xl font-extrabold tracking-tight text-pine-900">
            {service.shortName} Near You
          </h2>
          <p class="mx-auto mt-3 max-w-2xl text-center text-stone-600">
            We provide {service.shortName.toLowerCase()} across {SITE.serviceAreaSummary.toLowerCase()}. Find your
            city:
          </p>
          <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {regions.map((r) => (
              <div class="rounded-2xl border border-stone-200 bg-white p-6 shadow-sm">
                <h3 class="font-bold text-pine-900">{r.name}</h3>
                <div class="mt-3 flex flex-wrap gap-x-3 gap-y-1.5">
                  {citiesInRegion(r.slug).map((c) => (
                    <a
                      href={`/locations/${c.slug}/${service.slug}/`}
                      class="text-sm text-stone-500 hover:text-brass-700"
                    >
                      {c.name}
                    </a>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <FAQSection faqs={service.faqs} heading={`${service.shortName} FAQs`} />
  <CTABand heading={`Ready to talk about ${service.shortName.toLowerCase()}?`} />
</Layout>
