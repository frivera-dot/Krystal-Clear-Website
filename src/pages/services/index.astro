---
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import CTABand from "../../components/CTABand.astro";
import TrustBar from "../../components/TrustBar.astro";
import { services } from "../../data/services";

const floorSlugs = [
  "commercial-floor-care",
  "floor-stripping-and-waxing",
  "concrete-polishing",
  "marble-and-stone-polishing",
];
const floorServices = services.filter((s) => floorSlugs.includes(s.slug));
const otherServices = services.filter((s) => !floorSlugs.includes(s.slug));
---

<Layout
  title="Commercial Cleaning Services | KCS Krystal Clear Service"
  description="Full-service commercial cleaning: janitorial contracts, office cleaning, floor stripping & waxing, concrete & marble polishing, post-construction cleanup & more."
>
  <Breadcrumbs crumbs={[{ label: "Services" }]} />

  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6">
    <div class="max-w-3xl">
      <h1 class="text-4xl font-extrabold tracking-tight text-pine-900">Commercial Cleaning Services</h1>
      <p class="mt-4 text-lg leading-relaxed text-stone-600">
        One vendor for everything your facility needs — nightly janitorial, periodic deep cleans, construction
        cleanup, and the specialty floor care that made our name. Every crew is trained in-house, background-checked,
        and backed by a licensed, bonded &amp; insured company.
      </p>
    </div>

    <h2 class="mt-12 text-2xl font-extrabold tracking-tight text-pine-900">Janitorial &amp; Cleaning</h2>
    <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        otherServices.map((s) => (
          <a
            href={`/services/${s.slug}/`}
            class="group rounded-2xl border border-stone-200 bg-white p-6 shadow-sm transition hover:border-brass-200"
          >
            <h3 class="text-lg font-bold text-pine-900 group-hover:text-brass-700">{s.name}</h3>
            <p class="mt-2 text-sm leading-relaxed text-stone-600">{s.blurb}</p>
            <span class="mt-4 inline-block text-sm font-bold text-brass-600">Learn more →</span>
          </a>
        ))
      }
    </div>

    <h2 class="mt-14 text-2xl font-extrabold tracking-tight text-pine-900">
      Specialty Floor Care <span class="eyebrow ml-2 bg-brass-100 px-3 py-1 text-brass-800">Our Specialty</span>
    </h2>
    <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        floorServices.map((s) => (
          <a
            href={`/services/${s.slug}/`}
            class="group rounded-2xl border border-stone-200 bg-white p-6 shadow-sm transition hover:border-brass-200"
          >
            <h3 class="text-lg font-bold text-pine-900 group-hover:text-brass-700">{s.name}</h3>
            <p class="mt-2 text-sm leading-relaxed text-stone-600">{s.blurb}</p>
            <span class="mt-4 inline-block text-sm font-bold text-brass-600">Learn more →</span>
          </a>
        ))
      }
    </div>
  </section>

  <TrustBar />
  <CTABand />
</Layout>
