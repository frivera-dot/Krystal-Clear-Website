---
import Layout from "../layouts/Layout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { SITE } from "../config/site";
---

<Layout
  title="Terms of Service | KCS Krystal Clear Service"
  description="Terms governing the use of the KCS — Krystal Clear Service website."
>
  <Breadcrumbs crumbs={[{ label: "Terms of Service" }]} />
  <section class="copy mx-auto max-w-3xl px-4 py-10 text-slate-700 sm:px-6">
    <h1 class="mb-6 text-3xl font-extrabold tracking-tight text-navy-900">Terms of Service</h1>
    <p>
      Welcome to the website of {SITE.legalName}. By using this site, you agree to these terms.
    </p>
    <h2 class="mb-3 mt-8 text-xl font-bold text-navy-900">Website Content</h2>
    <p>
      The content on this site is provided for general information about our commercial cleaning services. While we
      work to keep it accurate and current, it does not constitute a binding offer. All service engagements are
      governed by a written quote or service agreement.
    </p>
    <h2 class="mb-3 mt-8 text-xl font-bold text-navy-900">Quotes &amp; Walkthroughs</h2>
    <p>
      Quote requests submitted through this site are not contracts. Pricing is confirmed only after an on-site
      walkthrough and delivered in a written quote.
    </p>
    <h2 class="mb-3 mt-8 text-xl font-bold text-navy-900">Intellectual Property</h2>
    <p>
      The KCS name, logo, and site content are the property of {SITE.legalName} and may not be reproduced without
      permission.
    </p>
    <h2 class="mb-3 mt-8 text-xl font-bold text-navy-900">Contact</h2>
    <p>
      Questions? Call {SITE.phone} or visit us at {SITE.address.street}, {SITE.address.city}, {SITE.address.state}
      {SITE.address.zip}.
    </p>
  </section>
</Layout>
